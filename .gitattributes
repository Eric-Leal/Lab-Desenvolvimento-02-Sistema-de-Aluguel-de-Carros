# Força LF para scripts executados em Linux/containers
mvnw text eol=lf
*.sh text eol=lf

# Windows scripts ficam com CRLF normalmente
*.bat text eol=crlf
*.cmd text eol=crlf

# Arquivos de texto genéricos
*.java text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.md text eol=lf
*.json text eol=lf
*.dockerfile text eol=lf
Dockerfile text eol=lf
