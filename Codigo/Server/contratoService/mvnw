#!/bin/sh
# shellcheck disable=SC2086

PRG="$0"
while [ -h "$PRG" ] ; do
  ls=`ls -ld "$PRG"`
  link=`expr "$ls" : '.*-> \(.*\)$'`
  if expr "$link" : '/.*' > /dev/null; then
    PRG="$link"
  else
    PRG=`dirname "$PRG"`"/$link"
  fi
done

MAVEN_HOME=`dirname "$PRG"`/..

# make it fully qualified
MAVEN_HOME=`cd "$MAVEN_HOME" > /dev/null && pwd`

# OS specific support.  $var _must_ be set to either true or false.
case "`uname`" in
  CYGWIN*) cygwin=true ;;
  MINGW*) mingw=true;;
  Darwin*) darwin=true
    #
    # Now change the issue for Cygwin, add the case to handle Windows g
    #
    case "`uname`" in
      CYGWIN*) echo "Running mvnw in Cygwin mode"; cygwin=true ;;
      MINGW*) echo "Running mvnw in MinGw mode"; mingw=true;;
    esac
    ;;
esac

if [ -z "$JAVA_HOME" ] ; then
  JAVA_HOME=`/usr/libexec/java_home`
fi

if [ -r /etc/profile ] ; then
  . /etc/profile
fi

# For Cygwin, ensure paths are in UNIX format before anything is touched
if $cygwin ; then
  [ -n "$JAVA_HOME" ] &&
    JAVA_HOME=`cygpath --unix "$JAVA_HOME"`
  [ -n "$CLASSPATH" ] &&
    CLASSPATH=`cygpath --path --unix "$CLASSPATH"`
fi

# For MINGW, ensure paths are in Unix format before anything is touched
if $mingw ; then
  [ -n "$JAVA_HOME" ] &&
    JAVA_HOME="`(cd "$JAVA_HOME"; pwd)`"
fi

if [ -z "$JAVA_HOME" ]; then
  javaExecutable="`which java`"
  if [ -n "$javaExecutable" ] && ! [ "`expr \"$javaExecutable\" : '\([^ ]*\)'`" = "No such file or directory" ]; then
    # readlink(1) doesn't work here because we're using sh not bash
    JAVA_HOME="`dirname \"$javaExecutable\"`/.."
    JAVA_HOME="`cd \"$JAVA_HOME\" > /dev/null && pwd`"
    if [ ! -d "$JAVA_HOME" ] ; then
      JAVA_HOME=/usr/share/java
    fi
  fi
fi

if [ -z "$JAVA_HOME" ] ; then
  echo "Error: JAVA_HOME is not properly set."
  exit 1
fi

# For Cygwin, switch paths to Windows
if $cygwin; then
  [ -n "$JAVA_HOME" ] &&
    JAVA_HOME=`cygpath --windows "$JAVA_HOME"`
  [ -n "$BASE_DIR" ] &&
    BASE_DIR=`cygpath --windows "$BASE_DIR"`
  [ -n "$CLASSPATH" ] &&
    CLASSPATH=`cygpath --path --windows "$CLASSPATH"`
fi

exec "$JAVA_HOME/bin/java" \
  $MAVEN_OPTS \
  -classpath "$MAVEN_HOME/boot/plexus-classworlds-2.7.0.jar" \
  "-Dclassworlds.conf=$MAVEN_HOME/bin/m2.conf" \
  "-Dmaven.home=$MAVEN_HOME" \
  "-Dlibrary.jansi.path=$MAVEN_HOME/lib/jansi-native" \
  "-Dmaven.multiModuleProjectDirectory=$PWD" \
  org.codehaus.plexus.classworlds.launcher.Launcher "$@"
