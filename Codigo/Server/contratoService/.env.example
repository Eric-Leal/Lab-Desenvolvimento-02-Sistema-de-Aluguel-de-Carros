# COLOQUE ESSAS VARIAVEIS EM .ENV (Valores para quando rodar DENTRO do Docker)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=aluguel-carro
DB_URL=jdbc:postgresql://postgres:5432/aluguel-carro
DB_USER=admin
DB_PASSWORD=admin

JWT_GENERATOR_SIGNATURE_SECRET=troque-esta-chave-jwt

MICRONAUT_SERVER_HOST=0.0.0.0
MICRONAUT_SERVER_PORT=8083

# COLOQUE ESSAS VARIAVEIS EM .ENV.LOCAL (Valores para quando rodar na sua máquina local via IDE/run-local.ps1)
DB_HOST=localhost
DB_PORT=5433
DB_URL=jdbc:postgresql://localhost:5433/aluguel-carro
